LIVE_ORDER_STATUS=false

# Telegram alerts — bot token + chat IDs now live in Mongo (finedge_telegram_bot
# collection, one doc per category: common/simulator/chart/algo/scanner), set via
# features.telegram_notifier.set_bot_config(). This stays an env var as the one
# instant kill-switch across every category, without needing a Mongo write to flip.
TELEGRAM_NOTIFICATIONS_ENABLED=true

# App user auth (JWT)
JWT_SECRET_KEY=3d6cd90a2568a9eebe4cfa2d064f2044578bdc5614f463e33fe3e824c28bd941
JWT_EXPIRE_MINUTES=10080
# Kill switch for get_current_user() across every simulator/trade route — see
# shared/features/auth.py. Turned on so per-user data (strategy ownership,
# subscription plan) can actually be scoped instead of resolving to anonymous.
AUTH_ENFORCEMENT_ENABLED=true

# Server-to-server auth between algo.trade's live_order_manager.py and algo.order's
# /order/broker/place|cancel|modify gateway — those calls have no logged-in user/JWT
# (background tick-processing, not a user request), so they use this shared secret
# header (X-Internal-Token) instead of app_auth.get_current_user.
INTERNAL_SERVICE_TOKEN=95bd2f6b317e01f6ef1b27b8550237d1146cd05905f23852eb9624f7424835b0

